# ============================================
# DATABASE
# ============================================
# Next.js app (Vercel) — use Supabase Transaction Pooler (port 6543, PgBouncer)
# Prevents serverless functions from exhausting connection limits.
# Supabase dashboard → Project Settings → Database → Connection string → Transaction pooler
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Python worker (Railway) — use Supabase Session Pooler or Direct connection (port 5432)
# Long-lived process; Transaction mode (PgBouncer) breaks multi-statement transactions.
# Supabase dashboard → Project Settings → Database → Connection string → Session pooler (port 5432)
DATABASE_URL_DIRECT=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Local development
# DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ============================================
# SUPABASE (JS client — for auth / real-time / client-side features)
# ============================================
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# ============================================
# AI ENRICHMENT
# ============================================
# Google Gemini API key (free tier: 1500 req/day)
# Get one at: https://aistudio.google.com/app/apikey
# Optional — AI summaries disabled if not set
GEMINI_API_KEY=

# ============================================
# DATA SOURCE API KEYS (all optional)
# ============================================
# NASA API key — improves rate limits for EONET
# Get one at: https://api.nasa.gov/
NASA_API_KEY=

# NASA FIRMS map key — required for wildfire satellite data
# Get one at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# ============================================
# WORKER CONFIGURATION
# ============================================
# Port for the FastAPI health endpoint
WORKER_PORT=8000

# ============================================
# NEXT.JS
# ============================================
# Base URL for the Next.js app (used for internal API calls)
NEXT_PUBLIC_APP_URL=http://localhost:3000
